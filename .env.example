# Your Omi Developer API Key (Required)
# Get this from the Omi app: Settings → Developer → Create Key
OMI_API_KEY=your_omi_api_key_here

# The Bluetooth MAC address of your Limitless Pendant.
# LEAVE THIS BLANK. The script auto-discovers your pendant on first run and saves it here.
PENDANT_MAC_ADDRESS=

# (Optional) Override the base directory for data storage.
# Defaults to the parent folder of the 'scripts' directory if left commented out.
# LIMITLESS_BASE_DIR=/Users/yourusername/omi

# --- Transcription Engine ---
# "macwhisper"     = Use MacWhisper watch-folder automation (default). MacWhisper must be running.
#                    Produces .dote files with speaker diarization (Speaker 1, Speaker 2, etc.)
# "faster-whisper" = Run transcribe.py directly as part of the pipeline. No GUI needed.
#                    Requires: pip install faster-whisper
#                    Note: no speaker diarization — all speech attributed to SPEAKER_00.
# "whisperx"       = Run transcribe_whisperx.py. Like faster-whisper but with speaker diarization.
#                    Requires: pip install whisperx  +  WHISPERX_HF_TOKEN set below.
TRANSCRIPTION_ENGINE=macwhisper

# --- faster-whisper / whisperx model settings ---
# Used when TRANSCRIPTION_ENGINE is "faster-whisper" or "whisperx".
# Model size: tiny | base | small | medium | large-v2 | large-v3
# Larger = more accurate but slower and more RAM. "base" is a good starting point.
WHISPER_MODEL=base
# Device: cpu | cuda (use cuda only if you have a compatible NVIDIA GPU)
WHISPER_DEVICE=cpu
# Compute type: int8 (fast, low RAM) | float16 | float32 (more accurate, more RAM)
WHISPER_COMPUTE=int8

# --- WhisperX diarization settings (only used when TRANSCRIPTION_ENGINE=whisperx) ---
# HuggingFace access token for the pyannote speaker diarization models.
# Steps to get one:
#   1. Create a free account at https://huggingface.co
#   2. Accept the license for both pyannote models (one-time click-through, free):
#        https://huggingface.co/pyannote/speaker-diarization-community-1
#        https://huggingface.co/pyannote/segmentation-3.0
#   3. Generate a token at https://huggingface.co/settings/tokens
#   4. Paste it here.
WHISPERX_HF_TOKEN=

# --- Speaker identification ---
# If set, only segments from this speaker label get is_user: true in Omi.
# All other speakers get is_user: false, so Omi correctly shows whose voice is whose.
# Example: USER_SPEAKER_LABEL=Speaker 1
# Leave blank to mark all segments as is_user: true (backwards-compatible default).
# Note: MacWhisper diarizes (labels speakers) but cannot identify which one is you.
# Check your MacWhisper output to find which label consistently appears for your voice.
USER_SPEAKER_LABEL=

# --- discarded_audio policy ---
# "keep" = move rejected files to the discarded_audio folder (default)
# "delete" = permanently delete rejected files immediately (no folder needed)
DISCARD_ACTION=keep

# How many days to retain files in discarded_audio before auto-deleting.
# Only applies when DISCARD_ACTION=keep. Set to 0 to keep forever.
DISCARD_RETENTION_DAYS=7

# --- synced_to_omi WAV policy ---
# "keep" = move WAV to synced_to_omi after a successful upload (default)
# "delete" = delete the WAV immediately after upload (keeps JSON only)
SYNCED_WAV_ACTION=keep

# How many days to retain WAV files in synced_to_omi before auto-deleting.
# Only applies when SYNCED_WAV_ACTION=keep. Set to 0 to keep forever.
SYNCED_WAV_RETENTION_DAYS=7

# --- synced_to_omi JSON policy ---
# How many days to retain JSON payload archives in synced_to_omi before auto-deleting.
# Set to 0 to keep forever.
SYNCED_JSON_RETENTION_DAYS=7

# --- Pendant health monitoring ---
# Enable only if you run the pendant in continuous/always-on recording mode.
# When enabled, the session counter is compared between syncs. A counter that hasn't
# advanced in 30+ minutes means the pendant has silently stopped recording — the fix
# is to hold the button for 2 seconds to stop, then hold again to restart.
# If you frequently start and stop the pendant manually this metric is not meaningful.
# Options: enabled | disabled (default: disabled)
PENDANT_HEALTH_MONITORING=disabled
